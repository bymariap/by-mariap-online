DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bymariap?schema=public
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# lax | strict | none. En prod usa "none" si el API está en otro dominio que los frontends.
COOKIE_SAMESITE=lax
SEED_ADMIN_EMAIL=admin@bymariap.com
SEED_ADMIN_PASSWORD=change-me-admin
PORT=3001
NODE_ENV=development
ADMIN_ORIGIN=http://localhost:5173,http://localhost:3000
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_INTEGRITY_SECRET=test_integ_xxx
WOMPI_EVENT_SECRET=test_event_xxx
WOMPI_API_URL=https://sandbox.wompi.co/v1
