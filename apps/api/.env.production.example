# =============================================================================
# Producción — plantilla. Copia a `.env` en el servidor y ajusta a tus valores
# reales. NO comitees el .env con secretos.
# =============================================================================

NODE_ENV=production
PORT=3001

# --- Base de datos ---
# Usa la cadena de conexión de tu proveedor (incluye sslmode=require si aplica).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/bymariap?schema=public&sslmode=require

# --- JWT ---
# Genera secretos largos y aleatorios (p.ej. `openssl rand -base64 48`).
# DEBEN ser distintos entre sí y nunca reutilizar los de desarrollo.
JWT_ACCESS_SECRET=__GENERA_UN_SECRETO_LARGO__
JWT_REFRESH_SECRET=__GENERA_OTRO_SECRETO_LARGO__
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# --- Cookies (sesión) ---
# COOKIE_SECURE: en producción SIEMPRE true (las cookies solo viajan por HTTPS).
COOKIE_SECURE=true
#
# COOKIE_DOMAIN: controla entre qué hosts se comparte la sesión.
#   - Subdominios bajo un mismo dominio (admin.bymariap.com + bymariap.com):
#       usa  .bymariap.com   → mantiene el SSO entre admin y storefront.
#   - Si quieres aislar admin y storefront, despliégalos en dominios distintos
#       y deja COOKIE_DOMAIN apuntando solo al host del API (o sin definir).
COOKIE_DOMAIN=.bymariap.com
#
# COOKIE_SAMESITE: "lax" | "strict" | "none".
#   - "lax" (recomendado): funciona cuando API y frontends comparten el mismo
#       dominio registrable (api.bymariap.com + bymariap.com).
#   - "none": OBLIGATORIO si el API vive en un dominio distinto al de los
#       frontends (cookies cross-site). Requiere COOKIE_SECURE=true (el código
#       lo fuerza automáticamente). Sin esto, NADIE podrá iniciar sesión en prod.
COOKIE_SAMESITE=lax

# --- Admin inicial (seed) ---
SEED_ADMIN_EMAIL=admin@bymariap.com
SEED_ADMIN_PASSWORD=__CAMBIA_ESTA_CONTRASENA__

# --- CORS ---
# Orígenes permitidos para enviar credenciales (cookies) al API. Incluye TANTO
# el admin como el storefront. Separados por coma, sin espacios, con esquema.
ADMIN_ORIGIN=https://admin.bymariap.com,https://bymariap.com

# --- Wompi (pagos) — usa las llaves de PRODUCCIÓN, no las de sandbox ---
WOMPI_PUBLIC_KEY=pub_prod_xxx
WOMPI_INTEGRITY_SECRET=prod_integ_xxx
WOMPI_EVENT_SECRET=prod_event_xxx
WOMPI_API_URL=https://production.wompi.co/v1

# --- Storage (Cloudflare R2) ---
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bymariap-media
R2_PUBLIC_BASE_URL=https://cdn.bymariap.com
