# Storefront — producción. Configura estos valores en Vercel como env vars.
# Las variables NEXT_PUBLIC_* se exponen al navegador; las demás solo al servidor.

# URL pública del API (Railway). Ejemplo: https://api.bymariap.up.railway.app
NEXT_PUBLIC_API_BASE_URL=https://api.bymariap.up.railway.app

# URL del API para llamadas server-side (puede ser igual a la pública en Railway)
API_INTERNAL_BASE_URL=https://api.bymariap.up.railway.app

# URL pública del storefront (para sitemap, og:url, etc.)
NEXT_PUBLIC_SITE_URL=https://bymariap.com

# Wompi — usar URL de producción
NEXT_PUBLIC_WOMPI_REDIRECT_BASE=https://checkout.wompi.co/p
